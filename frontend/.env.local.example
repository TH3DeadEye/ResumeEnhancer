# AWS Configuration
# Copy this file to .env.local and fill in your values

# AWS Region
AWS_REGION=us-east-1

# Amazon Cognito
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id
COGNITO_CLIENT_SECRET=your-client-secret

# S3 Buckets
S3_UPLOADS_BUCKET=your-uploads-bucket
S3_PARSED_BUCKET=your-parsed-bucket
S3_GENERATED_BUCKET=your-generated-bucket

# Lambda Functions
ENHANCEMENT_LAMBDA_NAME=your-enhancement-lambda
EXTRACTION_LAMBDA_NAME=your-extraction-lambda
PARSER_LAMBDA_NAME=your-parser-lambda
SCORING_LAMBDA_NAME=your-scoring-lambda
DOWNLOAD_LAMBDA_NAME=your-download-lambda

# DynamoDB
DYNAMODB_MASTER_RESUMES_TABLE=MasterResumes

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Amazon SES (Optional - for contact form)
SES_SENDER_EMAIL=noreply@your-domain.com
CONTACT_EMAIL=support@your-domain.com

# API Gateway (if using)
API_GATEWAY_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3001
